{
  "name": "consign",
  "version": "0.1.0",
  "module": "src/index.ts",
  "bin": {
    "consign": "./src/index.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "init": "bun run src/index.ts init",
    "build": "bun build src/index.ts --compile --target=bun --outfile=consign",
    "build:release": "bun run build:linux && bun run build:macos-arm64 && bun run build:macos-x64",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=consign-linux-x64",
    "build:macos-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=consign-darwin-arm64",
    "build:macos-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=consign-darwin-x64",
    "lint": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "execa": "^9.5.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
